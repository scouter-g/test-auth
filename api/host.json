{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "customHandler": {
    "description": {
      "arguments": ["--port", "%FUNCTIONS_CUSTOMHANDLER_PORT%"]
    }
  },
  "managedDependency": {
    "enabled": false
  }
}
